                // ICD slots arrive after async fetch — triggers coding save
                if (event.data.type === 'setIcdSlots') {
                    var icdSlots2      = event.data.icdSlots      || [];
                    var procedureHint2 = (event.data.procedureHint || '').toLowerCase();

                    var eligibleAmt2   = event.data.eligibleAmount  || 0;
                    var packageAmt2    = event.data.packageAmount   || 0;

                    // Most specific ICD code = last non-null slot
                    // Use doctor-selected ICD code from Diagnosis-Linked tab if provided
                    // Otherwise fall back to last populated slot from API lookup
                    var lastIcdCode2 = event.data.lastIcdCode || '';
                    if (!lastIcdCode2) {
                        for (var si2 = icdSlots2.length - 1; si2 >= 0; si2--) {
                            if (icdSlots2[si2] && icdSlots2[si2].code) { lastIcdCode2 = icdSlots2[si2].code; break; }
                        }
                    }
                    console.log('[ClaimAI] ICD code for coding row:', lastIcdCode2, event.data.lastIcdCode ? '(doctor selected)' : '(from API)');

                    // Match procedure from TPA master using exact Level3 names from DB
                    var procID2 = null;
                    try {
                        var tpaList2 = $.isArray(MasterData.mTPAProcedurecs)
                            ? MasterData.mTPAProcedurecs : $.parseJSON(MasterData.mTPAProcedurecs);

                        var isRight2 = /right/.test(procedureHint2);
                        var isLeft2  = /left/.test(procedureHint2);

                        // Determine claim type for procedure matching
                        var claimType2 = (window._claimAI_claimType || 'cataract').toLowerCase();

                        // Cataract rules (left/right eye variants)
                        var cataractRules = [
                            { kws: ['mics','micro incision'], l3r: 'MICS - Unifocal (Lens Included)-Right', l3l: 'MICS -Unifocal (Lens Included)-Left' },
                            { kws: ['multifocal'], l3r: 'MICS -Multifocal (Lens Included)-Right', l3l: 'MICS-Multifocal (Lens Included)-Left' },
                            { kws: ['toric'], l3r: 'Phaco with TORIC Lens(Any Lens)-Right', l3l: 'Phaco with TORIC Lens(Any Lens)-Left' },
                            { kws: ['phaco','phacoemulsification','cataract','senile','nuclear cataract','cortical'], l3r: 'Cataract Surgery Phacoemulsification -Unifocal Lens-Right', l3l: 'Cataract Surgery Phacoemulsification -Unifocal Lens-Left' },
                            { kws: ['trabeculectomy','glaucoma'], l3r: 'Trabeculectomy-Right', l3l: 'Trabeculectomy-Left' },
                            { kws: ['vitrectomy','vitreous','vitreal'], l3r: 'Vitrectomy-Right', l3l: 'Vitrectomy-Left' },
                            { kws: ['retinal detachment'], l3r: 'Retinal Detachment (Scleral Buckle)-Right', l3l: 'Retinal Detachment (Scleral Buckle)-Left' },
                            { kws: ['vegf','macular degeneration','intravitreal'], l3r: 'Monthly Intravitreal Anti-VEGF - Per Injection', l3l: 'Monthly Intravitreal Anti-VEGF - Per Injection' },
                            { kws: ['lasik'], l3r: 'LASIK-Right', l3l: 'LASIK-Left' },
                            { kws: ['pterygium'], l3r: 'Pterygium- Right Eye', l3l: 'Pterygium-Left Eye' },
                        ];

                        // Maternity rules — no left/right; uses delivery type keywords
                        // l3r and l3l both set to same value (no laterality for maternity)
                        // Order matters: MORE SPECIFIC rules FIRST so they win over generic ones
                        // Covers all 12 TPA procedure IDs: 402, 403, 404, 405, 418, 419, 420, 421, 422, 1331, 1332, 1340
                        var maternityRules = [
                            // ─── Caesarean Section rules (specific → general) ─────────────────
                            // ID 1332 — LSCS with well baby (explicit LSCS keyword)
                            { kws: ['lscs with well baby','lscs well baby','lscs single with well baby'], l3r: 'LSCS with well baby care(single),Rs.10000/- extra for twins', l3l: 'LSCS with well baby care(single),Rs.10000/- extra for twins' },
                            // ID 420 — Caesarean twins with well baby
                            { kws: ['caesarean twins with well baby','c-section twins with well baby','lscs twins with well baby','caesarean delivery twins'], l3r: 'Caesarean Delivery twins with well baby care', l3l: 'Caesarean Delivery twins with well baby care' },
                            // ID 419 — Caesarean delivery with well baby (single, NOT twins, NOT LSCS keyword)
                            { kws: ['caesarean delivery with well baby','c-section with well baby','caesarean with well baby'], l3r: 'Caesarean Delivery with well baby care', l3l: 'Caesarean Delivery with well baby care' },
                            // ID 421 — Caesarean Hysterectomy
                            { kws: ['caesarean hysterectomy','c-section hysterectomy','lscs hysterectomy'], l3r: 'Caesarean Hysterectomy with bladder repair', l3l: 'Caesarean Hysterectomy with bladder repair' },
                            // ID 422 — Complicated LSCS
                            { kws: ['complicated lscs','complicated caesarean','complicated c-section'], l3r: 'Complicated LSCS', l3l: 'Complicated LSCS' },
                            // ID 418 — Plain Caesarean (fallback for any C-section keyword)
                            { kws: ['lscs','caesarean','c-section','c section','cesarean'], l3r: 'Caesarean section', l3l: 'Caesarean section' },

                            // ─── Normal Delivery rules (specific → general) ────────────────────
                            // ID 1340 — Epidural WITH well baby
                            { kws: ['epidural with well baby','epidural delivery with well baby','epidural well baby'], l3r: 'Epidural delivery with well baby care(single/twins Rs.10000/- extra)', l3l: 'Epidural delivery with well baby care(single/twins Rs.10000/- extra)' },
                            // ID 404 — Normal Vaginal Delivery with Epidural (no well baby)
                            { kws: ['epidural anesthesia','vaginal delivery with epidural','normal vaginal delivery with epidural','epidural'], l3r: 'Normal Vaginal Delivery with Epidural Anesthesia', l3l: 'Normal Vaginal Delivery with Epidural Anesthesia' },
                            // ID 1331 — Normal delivery with well baby
                            { kws: ['normal delivery with well baby','normal with well baby','vaginal delivery with well baby','vaginal with well baby'], l3r: 'Normal delivery with well baby care(single) twins Rs.10000/- extra', l3l: 'Normal delivery with well baby care(single) twins Rs.10000/- extra' },
                            // ID 405 — Twins / Multiple pregnancy
                            { kws: ['vaginal delivery twins','normal delivery twins','twins','multiple pregnancy','twin delivery'], l3r: 'Normal Vaginal Delivery in Twins(Multiple pregnency)', l3l: 'Normal Vaginal Delivery in Twins(Multiple pregnency)' },
                            // ID 402/403 — Plain Normal Delivery (fallback)
                            { kws: ['normal vaginal delivery','vaginal delivery','normal delivery','spontaneous vaginal','svd'], l3r: 'Normal Delivery', l3l: 'Normal Delivery' },
                        ];

                        var procRules2 = (claimType2 === 'maternity') ? maternityRules : cataractRules;

                        var targetL3_2 = null;
                        for (var ri2 = 0; ri2 < procRules2.length; ri2++) {
                            var rr = procRules2[ri2];
                            if (rr.kws.some(function(kw){ return procedureHint2.indexOf(kw) !== -1; })) {
                                targetL3_2 = isLeft2 ? rr.l3l : rr.l3r;
                                break;
                            }
                        }

                        if (targetL3_2) {
                            var norm2 = targetL3_2.toLowerCase().replace(/[ \-–()]/g, '');
                            var best2 = 0;
                            for (var ti2 = 0; ti2 < tpaList2.length; ti2++) {
                                var t2 = tpaList2[ti2];
                                var tn2 = (t2.Name || t2.Level3 || '').toLowerCase().replace(/[ \-–()]/g, '');
                                var sc2 = (tn2 === norm2) ? 100 : 0;
                                if (!sc2) { targetL3_2.toLowerCase().split(' ').forEach(function(w){ if (w.length>2 && tn2.indexOf(w)!==-1) sc2+=10; }); }
                                if (sc2 > best2) { best2 = sc2; procID2 = t2.ID; }
                            }
                            if (best2 < 30) procID2 = null;
                        }
                    } catch(e) { console.warn('[ClaimAI] TPA match error:', e); }

                    if (procID2) {
                        console.log('[ClaimAI] setIcdSlots: procID=' + procID2 + ' icd=' + lastIcdCode2 + ' eligible=' + eligibleAmt2 + ' package=' + packageAmt2);
                        claimAI_saveCodingRow(procID2, lastIcdCode2, eligibleAmt2, packageAmt2);
                    } else {
                        console.warn('[ClaimAI] setIcdSlots: no procedure match, hint=' + procedureHint2);
                    }
                }
            });

