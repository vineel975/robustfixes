    // MutationObserver — re-apply Patient Condition if Spectra resets it after our restore
    setTimeout(function() {
        if (!window._claimAI_patientConditionId) return;
        var pcEl = document.getElementById('ddlPatientCondition');
        if (!pcEl) return;
        var obs = new MutationObserver(function() {
            if (pcEl.value !== window._claimAI_patientConditionId) {
                pcEl.value = window._claimAI_patientConditionId;
                console.log('[ClaimAI] MutationObserver re-applied PatientCondition:', window._claimAI_patientConditionId);
            }
        });
        obs.observe(pcEl, { attributes: true, childList: true, subtree: true });
        // Stop observing after 10 seconds (page should be stable by then)
        setTimeout(function() { obs.disconnect(); }, 10000);
    }, 1000);

