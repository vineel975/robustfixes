    function claimAI_restoreFields() {
        try {
            var claimIdForFac = $('#hdnClaimID').val();
            if (!claimIdForFac) return;
            var xhrFac = new XMLHttpRequest();
            xhrFac.open('GET', '/MedicalScrutiny/GetClaimFieldsForValidation?claimId=' + encodeURIComponent(claimIdForFac), false);
            xhrFac.send(null);
            if (xhrFac.status === 200) {
                var facFields = JSON.parse(xhrFac.responseText);
                console.log('[ClaimAI] claimAI_restoreFields response:', JSON.stringify(facFields),
