            // ── ClaimAI: Save Coding Row function ──────────────────────────────────
                window.claimAI_saveCodingRow = function(tpaProcID, lastIcdCodeStr, eligibleAmt, packageAmtFromIframe) {
                    var claimID     = $('#hdnClaimID').val();
                    var slNo        = $('#hdnClaimSlNo').val();
                    // Use iframe package amount if available, else fall back to Spectra coding section field
                    var packageAmt  = parseFloat(packageAmtFromIframe) > 0
                        ? parseFloat(packageAmtFromIframe)
                        : (parseFloat($('#txtTotalServicesPackageAmount').val()
                            || $('#txtbillingtotalpackageamount').val() || 0) || 0);

                    $.ajax({
                        url: '@Url.Action("SaveCodingRowForClaimAI", "MedicalScrutiny")',
                        type: 'POST',
                        data: {
                            claimId:        claimID,
                            slNo:           slNo,
                            tpaProcedureId: tpaProcID,
                            icdCodeStr:     lastIcdCodeStr  || '',
                            eligibleAmount: eligibleAmt     || 0,
                            packageAmount:  packageAmt      || 0
                        },
                        success: function(res) {
                            console.log('[ClaimAI] Coding saved:', res);
                            if (res && res.success) {
                                // Update BillingCorrection flag so Claim Actions validation passes
                                if (basicData && basicData[0]) {
                                    basicData[0].BillingCorrection = 2;
                                }
                                // Delay to allow DB commit before refreshing coding table
                                setTimeout(function() {
                                    if (typeof Retrieve_ClaimsCodingDetails === 'function') {
                                        Retrieve_ClaimsCodingDetails(claimID, slNo, 0);
                                    }
                                }, 2000);
                                var $toast = $('<div/>')
                                    .text('✓ Coding details saved')
                                    .css({ position:'fixed', bottom:'50px', right:'20px',
                                           background:'#2d6a9f', color:'#fff',
                                           padding:'8px 14px', borderRadius:'4px',
                                           fontSize:'13px', zIndex:99999,
                                           boxShadow:'0 2px 6px rgba(0,0,0,0.2)' })
                                    .appendTo('body');
                                setTimeout(function() { $toast.fadeOut(400, function(){ $toast.remove(); }); }, 3000);
                            } else {
                                console.warn('[ClaimAI] Coding save failed:', res && res.message);
                            }
                        },
                        error: function(xhr) {
                            console.warn('[ClaimAI] Coding save error:', xhr.responseText);
                        }
                    });

            // Watch for txtDoctorRemarks appearing in DOM (Notes tab is lazy-loaded)
