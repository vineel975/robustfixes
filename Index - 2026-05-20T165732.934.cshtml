    <script>
         window.IS_PAYTM_CLAIM = @((ViewData["AlertPaytmCorpClaims"] ?? "false").ToString().ToLower());
        $(document).ready(function () {
            GetInsurerRejectionMaster($('#hdnInsuranceCompanyID').val(), $('#hdnClaimProductID').val());
            var _claimIdOnLoad = $('#hdnClaimID').val();

            // Send facilityOptions + availedId to ClaimAI iframe after it loads
            function claimAI_sendFacilityOptions() {
                var iframe = document.getElementById('ifrClaimAI');
                if (!iframe || !iframe.contentWindow) return;
                var options = [];
                $('#ddlApprovedFacility option').each(function() {
                    var v = $(this).val(), t = $(this).text().trim();
                    if (v && t && t !== 'Select') options.push({ id: v.toString(), text: t });
                });
                if (options.length > 0) {
                    iframe.contentWindow.postMessage(
                        { source: 'spectra', type: 'setFacilityOptions',
                          options: options,
                          availedId: ($('#ddlReceivedAccomodation').val() || '').toString() },
                        '*'
                    );
                    console.log('[ClaimAI] Sent facilityOptions:', options.length, 'options, availedId:', $('#ddlReceivedAccomodation').val());
                }
            }
            $('#ifrClaimAI').on('load', function() {
                setTimeout(claimAI_sendFacilityOptions, 800);
            });



            // Detect claim type BEFORE InitAiSummary — synchronous call
            window._claimAI_claimType = 'other';
            window._claimAI_diagnosis = '';
            if (_claimIdOnLoad) {
                $.ajax({
                    url:   '/MedicalScrutiny/GetClaimType',
                    type:  'GET',
                    data:  { claimId: _claimIdOnLoad },
                    async: false,
                    success: function(res) {
                        if (res.success) {
                            window._claimAI_claimType = res.claimType;
                            window._claimAI_diagnosis = res.diagnosis;
                            console.log('[ClaimAI] Claim type from Diagnosis: "' + res.diagnosis + '" → ' + res.claimType.toUpperCase());
                        }
                    },
                    error: function() {
                        console.log('[ClaimAI] GetClaimType failed — defaulting to other');
                    }
                });
            }

            if (!RestoreAiSummaryIfSaved(_claimIdOnLoad)) {
                InitAiSummary(_claimIdOnLoad, $('#hdnClaimSlNo').val());
            }




            // Convert string value into a proper boolean
            if (window.IS_PAYTM_CLAIM) {
                alert("Sorry! Delayed claim intimation cannot be processed. HR approval is mandatory for further processing.");

                    $('#lnkQueryPending').hide();
                    $('#lnkInvestigation').hide();
                    $('#lnkRefertoInsurer').hide();
                    $('#lnkAdjudication').hide();
                    $('#btnReject,#btnRejectAll').removeAttr('disabled', true);
                    $('#btnApprove').hide();
                    $('#btnInsurerSubmit').removeAttr('disabled', true);
                    $('#btnInsurerResSubmit').attr('disabled', true);
                    $('#lnkReferCRM').show();
                    $('#SAA_lnkReviewReturn').hide();
                    $('#SAA_lnkReviewed').hide();
                    $('#lnkAuditToBilling').hide();
            }

        });

        // ── AI Summary — direct iframe to ClaimAI on http://localhost:3000 ─
        //
        // Flow:
        //  1. Read medical bill PDF from local disk  → GetMedicalBillDocument
        //  2. Read tariff PDF from local disk        → GetTariffDocument (optional)
        //  3. POST both base64 PDFs to Convex        → StartClaimAuditProxy (server bridges http→https)
        //  4. Get jobId back from Convex
        //  5. Set iframe src = http://localhost:3000/job/{jobId}?embedded=1
        //     Both Spectra and ClaimAI are on http:// → no Mixed Content, no proxy needed

        var _claimAiUrl = '@(System.Configuration.ConfigurationManager.AppSettings["ClaimAIUrl"] ?? "http://localhost:3000")';
        //  6. ClaimAI UI renders fully inside the iframe

        function RestoreAiSummaryIfSaved(claimID) {
            // After page reload following a Save, restore iframe from sessionStorage jobId
            var savedJobId  = sessionStorage.getItem('claimAI_jobId');
            var savedClaim  = sessionStorage.getItem('claimAI_claimId');
            if (!savedJobId || savedClaim !== claimID.toString()) return false;

            // Clear storage so next load starts fresh
            sessionStorage.removeItem('claimAI_jobId');
            sessionStorage.removeItem('claimAI_claimId');

            // Keep widget collapsed — user clicks + to expand
            var $widget = $('#divAiSummary');
            $widget.addClass('collapsed');
            $widget.find('.widget-body').hide();
            $widget.find('[data-icon-show]').each(function() {
                var $icon = $(this);
                $icon.removeClass($icon.data('icon-hide'));
                $icon.addClass($icon.data('icon-show'));
            });

            // Wire up the expand click to restore iframe (not reload AI)
            var ifrSrc = _claimAiUrl + '/job/' + encodeURIComponent(savedJobId) + '?embedded=1' + (window._claimAI_reqFacilityName ? '&availedAccom=' + encodeURIComponent(window._claimAI_reqFacilityName) : '');
            var $collapseBtn = $widget.find('[data-action="collapse"]');
            $collapseBtn.off('click.claimAIRestore').one('click.claimAIRestore', function() {
                $('#divAiLoading').hide();
                $('#divAiError').hide();
                $('#ifrClaimAI').attr('src', ifrSrc).show();
            });

            return true; // Restored — skip InitAiSummary
        }

        /*
         * ═══════════════════════════════════════════════════════════════════
         * CLAIMAI INTEGRATION — FULL FLOW WITH CHECKPOINTS
         * ═══════════════════════════════════════════════════════════════════
         *
         * STEP 1 → InitAiSummary
         *   Browser calls GetMedicalBillDocument → GetTariffDocument
         *   If STEP 1 fails → check browser console for [ClaimAI] logs
         *
         * STEP 2 → SubmitAndLoadIframe
         *   Browser POSTs to /MedicalScrutiny/StartClaimAuditProxy
         *   Spectra server forwards to ClaimAI (claim-helixview.fhpl.net)
         *   If STEP 2 fails → check StartClaimAuditProxy error message
         *
         * STEP 3 → ClaimAI processes PDF
         *   ClaimAI uploads to Convex storage → Convex runs AI
         *   If STEP 3 fails → check Convex dashboard logs
         *
         * STEP 4 → Iframe loads job result
         *   Browser loads iframe: {ClaimAIUrl}/job/{jobId}?embedded=1
         *   If STEP 4 fails → check if ClaimAI is accessible from browser
         *
         * STEP 5 → Save
         *   Iframe sends postMessages → Spectra saves to DB
         *   If STEP 5 fails → check individual save AJAX responses in console
         * ═══════════════════════════════════════════════════════════════════
         */
        function InitAiSummary(claimID, slNo) {
            // Check Claimsdetails directly before starting
            $.ajax({
                url:  '/MedicalScrutiny/IsClaimAISummaryAllowed',
                type: 'GET',
                data: { claimId: claimID, slNo: slNo },
                success: function(res) {
                    if (!res.allowed) {
                        showAiError('AI Summary not available: ' + res.reason);
                        return;
                    }
                    _doInitAiSummary(claimID, slNo);
                },
                error: function() {
                    _doInitAiSummary(claimID, slNo); // allow on error to avoid blocking
                }
            });
        }

        function _doInitAiSummary(claimID, slNo) {
            console.log('[ClaimAI] STEP 1 START: InitAiSummary. claimID:', claimID, 'slNo:', slNo, 'ClaimAI URL:', _claimAiUrl);

            // Check claim type — only proceed for cataract and maternity
            var _claimType = window._claimAI_claimType || 'other';
            console.log('[ClaimAI] claimType check for AI summary:', _claimType);
            if (_claimType !== 'cataract' && _claimType !== 'maternity') {
                showAiError('AI Summary is currently available only for Cataract and Maternity claims. This claim (' + _claimType + ') is not supported yet.');
                return;
            }

            // STAGING TEMPORARILY DISABLED — process every claim on-demand
            // To re-enable staging, uncomment the block below and remove the direct call
            // claimAI_fireWebhook(claimID, slNo);
            // claimAI_checkStagingAndLoad(claimID, slNo, function() {
            //     _doInitAiSummaryOnDemand(claimID, slNo);
            // });
            _doInitAiSummaryOnDemand(claimID, slNo);
        }

        function _doInitAiSummaryOnDemand(claimID, slNo) {
            showAiStatus('Loading medical bill...');

            $.ajax({
                url:  '/MedicalScrutiny/GetMedicalBillDocument',
                type: 'GET',
                data: { claimId: claimID, slNo: slNo },
                success: function(res) {
                    // STEP 1a RESULT: Medical bill fetch response
                    // If res.Success=false → check res.Message for CHECKPOINT details
                    // Common issues: zip not found, wrong claimId, Enviroment key mismatch
                    console.log('[ClaimAI] STEP 1a GetMedicalBillDocument:', res.Success, res.Message);
                    if (!res.Success || !res.Data || !res.Data.base64Content) {
                        showAiError('Could not load medical bill: ' + (res.Message || 'Check MedicalBillDocumentPath in Web.config'));
                        return;
                    }
                    var medB64      = res.Data.base64Content;
                    var medFileName = res.Data.fileName || 'medical-bill.pdf';
                    console.log('[ClaimAI] Medical bill loaded. File:', medFileName, 'Size(chars):', medB64.length);
                    showAiStatus('Loading tariff...');

                    $.ajax({
                        url:  '/MedicalScrutiny/GetTariffDocument',
                        type: 'GET',
                        data: { claimId: claimID },
                        success: function(tarRes) {
                            // STEP 1b RESULT: Tariff fetch response
                            // If tarRes.Success=false → tariff not found but processing continues without it
                            // Check tarRes.Message for CHECKPOINT details
                            console.log('[ClaimAI] STEP 1b GetTariffDocument:', tarRes.Success, tarRes.Message);
                            var tarB64 = null, tarFileName = null;
                            if (tarRes.Success && tarRes.Data && tarRes.Data.base64Content) {
                                tarB64      = tarRes.Data.base64Content;
                                tarFileName = tarRes.Data.fileName || 'tariff.pdf';
                                console.log('[ClaimAI] Tariff loaded. File:', tarFileName);
                            } else {
                                console.log('[ClaimAI] Tariff not loaded — proceeding without it.');
                            }
                            showAiStatus('Submitting to AI...');
                            SubmitAndLoadIframe(claimID, medB64, medFileName, tarB64, tarFileName);
                        },
                        error: function(xhr) {
                            console.log('[ClaimAI] GetTariffDocument error:', xhr.status, xhr.responseText);
                            // Tariff is optional — proceed without it
                            SubmitAndLoadIframe(claimID, medB64, medFileName, null, null);
                        }
                    });
                },
                error: function(xhr) {
                    console.error('[ClaimAI] GetMedicalBillDocument error:', xhr.status, xhr.responseText);
                    var d = '';
                    try { d = JSON.parse(xhr.responseText).Message || ''; } catch(e) {}
                    showAiError('HTTP ' + xhr.status + ': ' + (d || 'Could not load medical bill'));
                }
            });
        }

        function ReloadAiSummary() {
            $('#ifrClaimAI').hide().attr('src', '');
            $('#divAiError').hide();
            InitAiSummary($('#hdnClaimID').val(), $('#hdnClaimSlNo').val());
        }

        function showAiStatus(msg) {
            $('#divAiLoading').show();
            $('#divAiError').hide();
            $('#ifrClaimAI').hide();
            $('#spnAiStatus').text(msg);
        }

        function showAiError(msg) {
            $('#divAiLoading').hide();
            $('#ifrClaimAI').hide();
            $('#spnAiError').text(msg);
            $('#divAiError').show();
        }

        function SubmitAndLoadIframe(claimID, medB64, medFileName, tarB64, tarFileName) {
            console.log('[ClaimAI] SubmitAndLoadIframe. claimID:', claimID, 'hasTariff:', !!tarB64);

            // ── Collect Spectra field values from the DOM ─────────────────────────
            // These are the values already loaded from McarePlus DB into the page.
            // We pass them to ClaimAI so it can validate AI-extracted fields against
            // Spectra's values without needing a separate DB query from Convex.
            function getSpanText(id) {
                var el = document.getElementById(id);
                return el ? (el.innerText || el.textContent || '').trim() : '';
            }
            function getInputVal(id) {
                var el = document.getElementById(id);
                return el ? (el.value || '').trim() : '';
            }

            var spectraFields = {};

            // Patient name — strip "(Gender)" suffix that Spectra appends e.g. "John Doe(M)"
            // prefer system (DB) span, fallback to received input
            function stripGenderSuffix(name) {
                // Removes trailing (M), (F), (Male), (Female), (O), (Other) etc.
                return name.replace(/\s*\([MFOmfo][a-zA-Z]*\)\s*$/, '').trim();
            }
            var sysName = stripGenderSuffix(getSpanText('spnSystemPatient_PatientName'));
            var recName = getInputVal('txtReceivedPatient_PatientName');
            if (sysName)       spectraFields.patientName = sysName;
            else if (recName)  spectraFields.patientName = recName;

            // Gender — hidden field set from ViewData (numeric: 1=Female, 2=Male)
            var gender = getInputVal('hdnGender');
            if (gender) spectraFields.patientGender = gender;

            // Policy/UHID — basicData[0].uhidno is MemberPolicy.UHIDNO, which is what
            // ClaimAI's AI extracts as "policyNumber" from the bill
            if (typeof basicData !== 'undefined' && basicData[0] && basicData[0].uhidno) {
                spectraFields.policyNumber = basicData[0].uhidno.toString().trim();
            }
            if (!spectraFields.policyNumber) {
                var uhid = getInputVal('txtReceivedPatient_PatientUHID') ||
                           getSpanText('spnSystemPatient_InsurerUHID');
                if (uhid) spectraFields.policyNumber = uhid;
            }

            // Admission date — basicData[0].dateofadmission confirmed column name
            if (typeof basicData !== 'undefined' && basicData[0] && basicData[0].dateofadmission) {
                spectraFields.admissionDate = basicData[0].dateofadmission.toString().trim();
            }

            // Age, Hospital, Document Date — fetch from server synchronously
            // These are not in basicData; we get them via GetClaimFieldsForValidation
            try {
                var xhr = new XMLHttpRequest();
                xhr.open('GET', '/MedicalScrutiny/GetClaimFieldsForValidation?claimId=' + encodeURIComponent(claimID), false);
                xhr.send(null);
                if (xhr.status === 200) {
                    var fields = JSON.parse(xhr.responseText);
                    if (fields.age)          spectraFields.patientAge   = fields.age;
                    if (fields.hospitalName) spectraFields.hospitalName  = fields.hospitalName;
                    if (fields.documentDate) spectraFields.documentDate  = fields.documentDate;
                    if (fields.dischargeDate && !spectraFields.dischargeDate)
                                             spectraFields.dischargeDate = fields.dischargeDate;
                    if (fields.doctorNotes)  spectraFields.doctorNotes   = fields.doctorNotes;
                    if (fields.reqFacilityName)      spectraFields.availedAccommodation  = fields.reqFacilityName;
                    if (fields.approvedFacilityName) spectraFields.approvedAccommodation = fields.approvedFacilityName;
                    if (fields.reqFacilityId)   window._claimAI_reqFacilityId   = fields.reqFacilityId;
                    if (fields.reqFacilityName) window._claimAI_reqFacilityName = fields.reqFacilityName;
                    // Restore ApprovedFacilityID from DB on page load
                    // Do NOT trigger('change') — it causes Spectra handlers to reset it
                    if (fields.approvedFacilityId) {
                        window._claimAI_approvedFacilityId = fields.approvedFacilityId;
                        // Apply after all page load events have settled
                        var _savedFacId = fields.approvedFacilityId;
                        var _applyFacility = function() {
                            var $aprvDdl = $('#ddlApprovedFacility');
                                var _facToApply = 195; // ClaimAI: Always Day-care
                            if ($aprvDdl.find('option[value="' + _facToApply + '"]').length > 0) {
                                $aprvDdl.val(_facToApply);
                                console.log('[ClaimAI] ApprovedFacility restored silently:', _facToApply);
                            }
                        };
                        setTimeout(_applyFacility, 1000);
                        setTimeout(_applyFacility, 3000);
                    }
                }
            } catch(e) {
                console.warn('[ClaimAI] GetClaimFieldsForValidation failed:', e);
            }

            // Availed/Approved accommodation are now populated from DB via GetClaimFieldsForValidation above

            console.log('[ClaimAI] Spectra fields collected:', spectraFields);

            var payload = {
                claimId:            claimID.toString(),
                hospitalBillBase64: medB64,
                hospitalFileName:   medFileName
            };
            if (tarB64 && tarFileName) {
                payload.tariffBase64   = tarB64;
                payload.tariffFileName = tarFileName;
            }
            // Availed accommodation — send so ClaimAI can populate Aprv Accommodation on save
            var availedAccommId = $('#ddlReceivedAccomodation').val();
            if (availedAccommId) spectraFields.availedAccommodationId = availedAccommId.toString();

            // Full mFacility options so ClaimAI knows which IDs are valid
            var facilityOptions = [];
            $('#ddlApprovedFacility option').each(function() {
                var v = $(this).val(), t = $(this).text();
                if (v) facilityOptions.push({ id: v.toString(), text: t });
            });
            if (facilityOptions.length > 0) spectraFields.facilityOptions = facilityOptions;

            // MemberPolicyID and SlNo — needed for previous claims lookup
            spectraFields.memberPolicyId  = $('#hdnMemberPolicyID').val() || '';
            spectraFields.claimSlNo       = $('#hdnClaimSlNo').val() || '1';

            // claimType from Mst_PropoertyValues PropertyID=87
            // 466 = Cataract, 469 = Maternity
            // Use claim type already fetched at document ready
            spectraFields.claimType = window._claimAI_claimType || 'other';
            spectraFields.diagnosis = window._claimAI_diagnosis || '';

            // Doctor Notes — _claimAI_doctorNotes stores the value independently of DOM
            // txtDoctorRemarks only exists in DOM after Notes tab is opened
            window._claimAI_doctorNotes = '';
            spectraFields.doctorNotes = '';  // will be fetched by iframe via /api/doctor-notes

            // Only add spectraFields if at least one value was found
            if (Object.keys(spectraFields).length > 0) {
                payload.spectraFields = spectraFields;
            }

            $.ajax({
                url:         '/MedicalScrutiny/StartClaimAuditProxy',
                type:        'POST',
                contentType: 'application/json',
                data:        JSON.stringify(payload),
                timeout:     120000,
                success: function(res) {
                    // STEP 2 RESULT: StartClaimAuditProxy response
                    // SUCCESS → res.Data.jobId exists → iframe will load
                    // FAILURE → check res.Message for exact CHECKPOINT:
                    //   CHECKPOINT 1d FAILED → Spectra cannot reach ClaimAI server
                    //     Fix: check ClaimAIUrl in Web.config, check ClaimAI is running (pm2 status)
                    //   CHECKPOINT 1e FAILED → ClaimAI returned error HTTP status
                    //     Fix: check ClaimAI Next.js logs on EC2
                    //   CHECKPOINT 1f FAILED → ClaimAI reached but Convex failed
                    //     Fix: check NEXT_PUBLIC_CONVEX_URL in ClaimAI .env.local on EC2
                    console.log('[ClaimAI] STEP 2 StartClaimAuditProxy:', res.Success, res.Message, res.Data);
                    if (!res.Success || !res.Data || !res.Data.jobId) {
                        showAiError('Convex error: ' + (res.Message || 'No jobId returned'));
                        return;
                    }
                    // STEP 3/4: Load iframe with job result
                    // If iframe shows login page → ClaimAI auth check is blocking access.
                    // Fix: in ClaimAI job-page.tsx, bypass auth when ?embedded=1 is in URL.
                    // See job-page.tsx auth check useEffect.
                    var jobId = res.Data.jobId;
                    var src   = _claimAiUrl + '/job/' + encodeURIComponent(jobId) + '?embedded=1' + (window._claimAI_reqFacilityName ? '&availedAccom=' + encodeURIComponent(window._claimAI_reqFacilityName) : '');
                    console.log('[ClaimAI] STEP 3/4 Loading iframe:', src);
                    $('#divAiLoading').hide();
                    $('#ifrClaimAI').attr('src', src).show();

                    // STAGING TEMPORARILY DISABLED — store-job call commented out
                    // var _stgKey = '@System.Configuration.ConfigurationManager.AppSettings["StagingApiKey"]' || '';
                    // $.ajax({
                    //     url:         _claimAiUrl + '/api/staging/store-job',
                    //     method:      'POST',
                    //     contentType: 'application/json',
                    //     headers:     { 'x-api-key': _stgKey },
                    //     data:        JSON.stringify({ claimId: claimID.toString(), slNo: ($('#hdnClaimSlNo').val() || '1').toString(), jobId: jobId }),
                    //     success: function() { console.log('[ClaimAI] Staging: jobId stored for future fast load'); },
                    //     error:   function() { console.log('[ClaimAI] Staging: store-job failed (non-critical)'); }
                    // });


                },
                error: function(xhr) {
                    console.error('[ClaimAI] StartClaimAuditProxy error:', xhr.status, xhr.responseText);
                    var d = '';
                    try { d = JSON.parse(xhr.responseText).Message || ''; } catch(e) {
                        d = xhr.responseText
                            ? xhr.responseText.replace(/<[^>]+>/g, '').trim().substring(0, 200)
                            : 'HTTP ' + xhr.status;
                    }
                    showAiError('Submission failed: ' + (d || 'Unknown error'));
                }
            });
        }


