        <script>
        // claimAI_applyRestriction — global scope so it can be called from any script block
        function claimAI_applyRestriction() {
            var claimId = $('#hdnClaimID').val();
            var slNo    = $('#hdnClaimSlNo').val();
            if (!claimId) return;

            $.ajax({
                url:  '/MedicalScrutiny/IsClaimAISummaryAllowed',
                type: 'GET',
                data: { claimId: claimId, slNo: slNo },
                success: function(res) {
                    console.log('[ClaimAI] Restriction check:', res);
                    var $aiBtn = $('#divBillcalculation .lnkCashlessLog');
                    if ($aiBtn.length === 0) $aiBtn = $('.lnkCashlessLog').last();

                    if (res.allowed) {
                        $aiBtn.css({ opacity: '', pointerEvents: '', cursor: '' })
                              .attr('title', 'AI Summary');
                    } else {
                        $aiBtn.css({ opacity: '0.35', pointerEvents: 'none', cursor: 'not-allowed' })
                              .attr('title', 'AI Summary not available: ' + res.reason);
                        $('#ifrClaimAI').hide().attr('src', '');
                        window._claimAI_jobId = null;
                    }
                },
                error: function() {
                    console.warn('[ClaimAI] IsClaimAISummaryAllowed check failed');
                }
            });
        }

        $(function() {
            if(basicData[0].IsBufferEnabled==true){
                checkBufferClaim();
            }

            // Listen for postMessage from ClaimAI iframe
            window.addEventListener('message', function(event) {
                if (!event.data || event.data.source !== 'claimai') return;
                console.log('[ClaimAI] postMessage received:', event.data.type, JSON.stringify(event.data).substring(0, 120));

                if (event.data.type === 'setApprovedAccommodation') {
                    // Approved accommodation = Availed accommodation (same)
                    // Read directly from ddlReceivedAccomodation (availed)
                    var availedFacilityId = $('#ddlReceivedAccomodation').val() || event.data.facilityId;
                    console.log('[ClaimAI] setApprovedAccommodation: using availed value:', availedFacilityId);

                    if (availedFacilityId) {
                        var $ddlApprv = $('#ddlApprovedFacility');
                        // Temporarily enable, set value, re-disable
                        $ddlApprv.removeAttr('disabled');
                        $ddlApprv.val(availedFacilityId);
                        $ddlApprv.attr('disabled', 'disabled');
                        window._claimAI_approvedFacilityId = availedFacilityId;
                        console.log('[ClaimAI] ddlApprovedFacility set to:', availedFacilityId);
                    }

                    // Set ICU Days = 1 for cataract day-care cases
                    var $icuDays = $('#txtICUDays');
                    if ($icuDays.length) {
                        $icuDays.removeAttr('disabled').val('1').attr('disabled', 'disabled');
                        console.log('[ClaimAI] ICU Days set to 1');
                    }
                    // Also update hdnDaysDetails JSON: [ICUDays, RoomDays]
                    // hdnDaysDetails is read by Spectra's billing validation
                    try {
                        var _daysArr = [1, 0]; // ICU=1, Room=0 for day-care cataract
                        var _existingDays = $('#hdnDaysDetails').val();
                        if (_existingDays && _existingDays !== '') {
                            var _parsed = $.parseJSON(_existingDays);
                            if (_parsed && _parsed.length >= 2) {
                                _daysArr = [1, _parsed[1]]; // Keep room days, override ICU=1
                            }
                        }
                        $('#hdnDaysDetails').val(JSON.stringify(_daysArr));
                        console.log('[ClaimAI] hdnDaysDetails updated:', JSON.stringify(_daysArr));
                    } catch(e) {
                        console.warn('[ClaimAI] hdnDaysDetails update failed:', e);
                    }
                }

                if (event.data.type === 'copyAvailedToApproved') {
                    var availedVal = $('#ddlReceivedAccomodation').val();
                    console.log('[ClaimAI] copyAvailedToApproved - availed val:', availedVal);
                    // Set ICU Days = 1
                    try {
                        var $icuF = $('#txtICUDays');
                        if ($icuF.length) {
                            $icuF.removeAttr('disabled').val('1').attr('disabled', 'disabled');
                            console.log('[ClaimAI] ICU Days set to 1');
                            var _dv = $('#hdnDaysDetails').val();
                            var _da = [1, 0];
                            if (_dv && _dv !== '') {
                                var _dp = $.parseJSON(_dv);
                                if (_dp && _dp.length >= 2) _da = [1, _dp[1]];
                            }
                            $('#hdnDaysDetails').val(JSON.stringify(_da));
                        }
                    } catch(e) { console.warn('[ClaimAI] ICU err:', e); }
                    if (availedVal) {
                        var $aprvDdl = $('#ddlApprovedFacility');
                        if ($aprvDdl.find('option[value="' + availedVal + '"]').length > 0) {
                            $aprvDdl.val(availedVal).trigger('change');
                        }
                    }
                    window._claimAI_approvedFacilityId = availedVal || '';
                }

                if (event.data.type === 'setClinicalDetails') {
                    var diagnosis            = event.data.diagnosis            || '';
                    var lineOfTreatment      = event.data.lineOfTreatment      || '';
                    var presentingComplaint  = event.data.presentingComplaint  || '';
                    var hospTreatmentKeyword = event.data.hospTreatmentKeyword || '';
                    var icdSlots             = event.data.icdSlots             || [];
                    var eligibleAmount       = event.data.eligibleAmount       || 0;


                    // Probable Diagnosis → txtProbableDiagnosis (always populate)
                    if (diagnosis) {
                        $('#txtProbableDiagnosis').val(diagnosis).trigger('change');
                    }

                    // Treatment Details → txtProbableLineOfTreatment (always populate)
                    var treatmentValue = lineOfTreatment || diagnosis;
                    if (treatmentValue) {
                        $('#txtProbableLineOfTreatment').val(treatmentValue).trigger('change');
                    }

                    // Presenting Complaint → txtPresentComplaint
                    if (presentingComplaint) {
                        $('#txtPresentComplaint').val(presentingComplaint).trigger('change');
                    }

                    // Processing Remarks → txtExecutiveNotes
                    var processingRemarks = event.data.processingRemarks || '';
                    if (processingRemarks) {
                        $('#txtExecutiveNotes').val(processingRemarks).trigger('change');
                    }

                    // Doctor Notes — store in closure var (DOM may not exist if Notes tab not opened)
                    var doctorNotes = event.data.doctorNotes || '';
                    if (doctorNotes) {
                        window._claimAI_doctorNotes = doctorNotes;
                        // Set in DOM only if element exists (Notes tab opened)
                        if ($('#txtDoctorRemarks').length) {
                            $('#txtDoctorRemarks').val(doctorNotes).trigger('change');
                        }
                    }

                    // Probable Line of Treatment → ddlHospTreatmentType
                    if (hospTreatmentKeyword) {
                        var $hospDdl = $('#ddlHospTreatmentType');
                        var matchedVal = null;
                        $hospDdl.find('option').each(function () {
                            if ($(this).text().toLowerCase().indexOf(hospTreatmentKeyword) !== -1) {
                                matchedVal = $(this).val();
                                return false;
                            }
                        });
                        console.log('[ClaimAI] hospTreatmentKeyword:', hospTreatmentKeyword, 'matchedVal:', matchedVal);
                        if (matchedVal) $hospDdl.val(matchedVal).trigger('change');
                    }

                    // Coding save is handled by setIcdSlots postMessage (sent after ICD fetch)

                    // ── Hospitalization Details save (ClaimAI) ───────────────────────────────
                    // Saves: ApprovedFacility (= availed), ICU=1, Room=0, BillNo=135 (if blank)
                    // Writes directly to DB via SaveHospitalizationDetailsForClaimAI,
                    // AND populates the DOM fields so the manual Save button also persists them.
                    try {
                        // ClaimAI: Always set Approved Accommodation to Day-care (195)
                        var claimAI_availed  = document.getElementById('ddlReceivedAccomodation');
                        var claimAI_approved = document.getElementById('ddlApprovedFacility');
                        var claimAI_approvedFacId = '195';
                        console.log('[ClaimAI] availed el:', claimAI_availed,
                            'availed.value:', claimAI_availed ? claimAI_availed.value : 'NO ELEMENT',
                            'window._claimAI_approvedFacilityId:', window._claimAI_approvedFacilityId,
                            'final approvedFacId:', claimAI_approvedFacId);
                        if (claimAI_approved && claimAI_approvedFacId) {
                            claimAI_approved.disabled = false;
                            claimAI_approved.value    = claimAI_approvedFacId;
                            window._claimAI_approvedFacilityId = claimAI_approvedFacId;
                        }

                        // 2. Room/ICU days — leave as-is (preserve Spectra values)

                        // 3. Mark facility as changed in memory so Fill_HospitalizationDetails
                        //    does not reset ddlApprovedFacility to 0 on this session
                        if (typeof basicData !== 'undefined' && basicData[0]) {
                            basicData[0].IsAprvFacilitychanged = 1;
                        }

                        // 4. Bill No — use existing value if present, else default to '135'
                        var claimAI_billEl = document.getElementById('txtBillNo');
                        var claimAI_billVal = '';
                        if (claimAI_billEl) {
                            claimAI_billVal = (claimAI_billEl.value || '').trim();
                            if (!claimAI_billVal) claimAI_billVal = '135';
                            claimAI_billEl.disabled = false;
                            claimAI_billEl.value    = claimAI_billVal;
                            console.log('[ClaimAI] BillNo set to:', claimAI_billVal);
                        }

                        // 5. Persist directly to DB (bypasses form serialization issues)
                        $.ajax({
                            url:  '@Url.Action("SaveHospitalizationDetailsForClaimAI", "MedicalScrutiny")',
                            type: 'POST',
                            data: {
                                claimId:           $('#hdnClaimID').val(),
                                slNo:              $('#hdnClaimSlNo').val(),
                                approvedFacilityId: claimAI_approvedFacId,
                                billNo:            claimAI_billVal
                            },
                            success: function(res) {
                                console.log('[ClaimAI] SaveHospitalizationDetailsForClaimAI:', res);
                                if (res && res.success) {
                                    // Update in-memory flag so Claim Actions validation passes
                                    if (basicData && basicData[0]) {
                                        basicData[0].IsAprvFacilitychanged = 1;
                                    }
                                    $('#hdnIsFacilityChanged').val('false');
                                    var $t = $('<div/>').text('✓ Accommodation & room details saved')
                                        .css({ position:'fixed', bottom:'140px', right:'20px',
                                               background:'#1565C0', color:'#fff',
                                               padding:'8px 14px', borderRadius:'4px',
                                               fontSize:'13px', zIndex:99999,
                                               boxShadow:'0 2px 6px rgba(0,0,0,0.2)' })
                                        .appendTo('body');
                                    setTimeout(function(){ $t.fadeOut(400, function(){ $t.remove(); }); }, 2500);
                                } else {
                                    console.warn('[ClaimAI] Hosp save failed:', res && res.message);
                                }
                            },
                            error: function(xhr) { console.warn('[ClaimAI] Hosp save error:', xhr.responseText); }
                        });

                    } catch(claimAI_err) { console.warn('[ClaimAI] Hosp details error:', claimAI_err); }

                    // Auto-save hospitalization details — delay 500ms to ensure
                    // setApprovedAccommodation postMessage has already fired and set window._claimAI_approvedFacilityId
                    setTimeout(function () {
                        var claimDetailsId = $('#hdnClaimDetailsID').val() || '';
                        var hospTypeId     = $('#ddlHospTreatmentType').val() || '';

                        // Approved facility — use stored value from setApprovedAccommodation
                        // fallback to current dropdown value
                        var approvedFacId = window._claimAI_approvedFacilityId || $('#ddlApprovedFacility').val() || '';
                        console.log('[ClaimAI] SaveClinical FULL DEBUG:',
                            'claimDetailsId:', claimDetailsId,
                            'approvedFacId:', approvedFacId,
                            'window._claimAI_approvedFacilityId:', window._claimAI_approvedFacilityId,
                            'ddlApprovedFacility.val():', $('#ddlApprovedFacility').val(),
                            'ddlApprovedFacility.is(:disabled):', $('#ddlApprovedFacility').is(':disabled'),
                            'ddlApprovedFacility options count:', $('#ddlApprovedFacility option').length,
                            'diagnosis:', $('#txtProbableDiagnosis').val());

                        $.ajax({
                            url: '@Url.Action("SaveClinicalDetailsForClaimAI", "MedicalScrutiny")',
                            type: 'POST',
                            data: {
                                claimDetailsId:          claimDetailsId,
                                probableDiagnosis:       $('#txtProbableDiagnosis').val(),
                                probableLineOfTreatment: $('#txtProbableLineOfTreatment').val(),
                                presentComplaint:        $('#txtPresentComplaint').val(),
                                processingRemarks:       $('#txtExecutiveNotes').val(),
                                doctorNotes:             window._claimAI_doctorNotes || '',
                                hospTreatmentTypeId:     hospTypeId,
                                approvedFacilityId:      approvedFacId
                            },
                            success: function (res) {
                                console.log('[ClaimAI] SaveClinicalDetailsForClaimAI response:', JSON.stringify(res));
                                if (res && res.success) {
                                    // Set Patient Condition dropdown to "Recovered" (ID=269)
                                    var $pcDdl = $('#ddlPatientCondition');
                                    if ($pcDdl.length && $pcDdl.find('option[value="269"]').length > 0) {
                                        $pcDdl.val('269').trigger('change');
                                        console.log('[ClaimAI] PatientCondition set to Recovered (269)');
                                    }

                                    // Update txtDoctorRemarks in DOM if Notes tab is open
                                    if (window._claimAI_doctorNotes && $('#txtDoctorRemarks').length) {
                                        $('#txtDoctorRemarks').val(window._claimAI_doctorNotes);
                                    }
                                    var $toast = $('<div/>')
                                        .text('✓ Hospitalization details saved')
                                        .css({
                                            position: 'fixed', bottom: '20px', right: '20px',
                                            background: '#3c763d', color: '#fff',
                                            padding: '8px 14px', borderRadius: '4px',
                                            fontSize: '13px', zIndex: 99999,
                                            boxShadow: '0 2px 6px rgba(0,0,0,0.2)'
                                        }).appendTo('body');
                                    setTimeout(function () {
                                        $toast.fadeOut(400, function () { $toast.remove(); });
                                    }, 2500);
                                }
                            },
                            error: function (xhr) {
                                console.warn('[ClaimAI] Clinical details auto-save failed:', xhr.responseText);
                            }
                        });
                    }, 500);
                }

                // Doctor Notes sync from iframe
                if (event.data.type === 'setDoctorNotes') {
                    var doctorNotesVal = event.data.doctorNotes || '';
                    window._claimAI_doctorNotes = doctorNotesVal;
                    $('#txtDoctorRemarks').val(doctorNotesVal).trigger('change');
                }

                // Bill Details automation from ClaimAI
                if (event.data.type === 'getCodingProcedureLimit') {
                    var _claimIdForLimit = event.data.claimId || $('#hdnClaimID').val();
                    console.log('[ClaimAI] getCodingProcedureLimit received, claimId=', _claimIdForLimit, 'claimType=', window._claimAI_claimType);
                    $.ajax({
                        url: '/MedicalScrutiny/GetCodingProcedureEligibleLimit',
                        type: 'GET',
                        data: {
                            claimId:        _claimIdForLimit,
                            slNo:           $('#hdnClaimSlNo').val() || '1',
                            providerID:     $('#hdnProviderID').val() || '0',
                            policyID:       $('#hdnPolicyID').val() || '0',
                            memberPolicyID: $('#hdnMemberPolicyID').val() || '0',
                            issueID:        $('#hdnInsuranceCompanyID').val() || '0',
                            corpID:         $('#hdnCorporateID').val() || '0',
                            payerID:        $('#hdnPayerID').val() || '0',
                            brokerID:       $('#hdnBrokerID').val() || '0',
                            siTypeID:       $('#hdnSITypeID').val() || '0',
                            claimType:      window._claimAI_claimType || 'cataract'
                        },
                        success: function(res) {
                            console.log('[ClaimAI] GetCodingProcedureEligibleLimit:', res);
                            var iframe = document.getElementById('ifrClaimAI');
                            if (iframe && iframe.contentWindow) {
                                iframe.contentWindow.postMessage(
                                    { source: 'spectra', type: 'codingProcedureLimitResult',
                                      success: res.success, eligibleAmount: res.eligibleAmount,
                                      ruleName: res.ruleName, remarks: res.remarks,
                                      noLimit: res.noLimit, warning: res.warning,
                                      limits: res.limits, utilized: res.utilized },
                                    '*'
                                );
                            }
                        },
                        error: function(xhr) {
                            var iframe = document.getElementById('ifrClaimAI');
                            if (iframe && iframe.contentWindow) {
                                iframe.contentWindow.postMessage(
                                    { source: 'spectra', type: 'codingProcedureLimitResult', success: false, error: 'Request failed: ' + xhr.status },
                                    '*'
                                );
                            }
                        }
                    });
                }

                if (event.data.type === 'setBillingDetails') {
                    var hospBillAmt        = event.data.hospitalBillAmount  || 0;
                    var tariffBillAmt      = event.data.tariffAmount         || 0;
                    var totalAmtApproved   = event.data.totalAmountApproved || 0;
                    var claimID2           = $('#hdnClaimID').val();
                    var slNo2              = $('#hdnClaimSlNo').val();


                    $.ajax({
                        url:  '@Url.Action("SaveBillingForClaimAI", "MedicalScrutiny")',
                        type: 'POST',
                        data: {
                            claimId:            claimID2,
                            slNo:               slNo2,
                            hospitalBillAmount: hospBillAmt,
                            tariffAmount:       tariffBillAmt,
                            totalAmountApproved: totalAmtApproved
                        },
                        success: function(res) {
                            console.log('[ClaimAI] SaveBilling response:', res);
                            if (res && res.success) {
                                // Update in-memory flag so Claim Actions billing validation passes
                                if (basicData && basicData[0]) {
                                    basicData[0].BillingCorrection = 2;
                                }
                                // Refresh Bill Details — call Get_ServiceBillingDetails directly
                                // It's defined in BillingPartialView and available globally
                                setTimeout(function() {
                                    var claimIDVal = $('#hdnClaimID').val();
                                    var slNoVal    = $('#hdnClaimSlNo').val();
                                    if (typeof Get_ServiceBillingDetails === 'function') {
                                        Get_ServiceBillingDetails(claimIDVal, slNoVal, 0);
                                    } else {
                                        // Force reload by eval-ing the onclick directly
                                        var lnk = document.getElementById('ID_Servicebilldetails');
                                        if (lnk) {
                                            var onclickStr = lnk.getAttribute('onclick');
                                            if (onclickStr) eval(onclickStr);
                                        }
                                    }
                                }, 1500);
                                var $toast = $('<div/>')
                                    .text('✓ Bill details saved')
                                    .css({
                                        position: 'fixed', bottom: '80px', right: '20px',
                                        background: '#5b4fcf', color: '#fff',
                                        padding: '8px 14px', borderRadius: '4px',
                                        fontSize: '13px', zIndex: 99999,
                                        boxShadow: '0 2px 6px rgba(0,0,0,0.2)'
                                    }).appendTo('body');
                                setTimeout(function() {
                                    $toast.fadeOut(400, function() { $toast.remove(); });
                                }, 3000);
