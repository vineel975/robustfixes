                                tableData.push({ ID: theData[index].Pincode, Name: theData[index].Pincode });
                            });
                            if (tableData != undefined && tableData.length > 0)
                                AutoCompleteDataBaseLenth(tableData, ID_value, ID_value);
                            else {
                                alert("Given Pincode not in the Database.");
                                $("#" + ID_value).val("");
                            }


                        },


                    });

            }

            $("#btnManualPushiAI").click(function () {
                var objClaimData = new Object();
                objClaimData.ClaimId = $('#hdnClaimID').val();
                objClaimData.Slno = $('#hdnClaimSlNo').val();

                $.ajax({
                    type: 'GET',
                    url: '@Url.Action("pushReuploadedDocumentToIAI", "MedicalScrutiny")',
                    data: { claimData: JSON.stringify(objClaimData) },
                    dataType: "json",
                    contentType: "application/json; charset=utf-8",
                    async: false,
                    cache: false,
                    success: function (resData) {
                        var objData = JSON.parse(resData);
                        if (objData[0].Result) {
                            window.location.href = '/claims/Index';
                        }
                        else if (!objData[0].Result && objData[0].ResponseText == "ErrorCode#1") {
                            CheckSessionVariable(objData[0].ResponseText);
                        }
                        else {
                            DialogWarningMessage(objData[0].ResponseText);
                        }
                    },
                    error: function (err, xhr) {
                        console.log(err.statusText);
                        DialogErrorMessage(err.statusText);
                    }
                });
            });

        </script>
    }