            function SaveOptionalCovers(val, COCID, OptionalCoverID) {
                var Action = "";
                if ($("#chk_" + val).prop("checked") == true) {
                    var Current_Amount = parseInt($("#txtOpCoverCurrent" + val).val());
                    var Actual_Amount = parseInt($("#txtOpCoverActualAmount" + val).text());
                    var Balance_Amount = parseInt($("#txtOpCoverBalanceAmount" + val).text());
                    var txtOpOLDAmount = parseInt($("#txtOpOLDAmount" + val).text());
                    var txtOpOLDGivenAmount = parseInt($("#txtOpOLDGivenAmount" + val).text());
                    var txtBlockedAmount = parseInt($("#txtBlockedAmount" + val).text());
                    var txtUtilizedAmount = parseInt($("#txtUtilizedAmount" + val).text());

                    if (Actual_Amount != 0) {
                        if (txtBlockedAmount != txtOpOLDGivenAmount) {
                            if ((Balance_Amount + txtOpOLDAmount) < Current_Amount) {
                                alert("Amount should not exceed Balance Amount");
                                return;
                            }
                        }
                        else if ((Actual_Amount != Current_Amount && Actual_Amount < Current_Amount) || (Actual_Amount<(txtUtilizedAmount + Current_Amount))) {
                            alert("Amount should not exceed Balance Amount");
                            return;
                        }
                        else if (Balance_Amount == 0) {
                            alert("Amount should not exceed Balance Amount");
                            return;
                        }

                    }
                    if (COCID == "" || COCID == null) {
                        Action = "INSERT";
                    }
                    else {
                        Action = "UPDATE";
                    }
                }
                else
                {
                    Action = "DELETE";
                }
                $.ajax
                    (
                    {
                        url: '@Url.Action("SaveClaimOptionalCovers", "MedicalScrutiny")',
                        type: 'POST',
                            data: { Action: Action, CLAIMID: $('#hdnClaimID').val(), SLNO: $('#hdnClaimSlNo').val(), MemberPolicyId: $('#hdnMemberPolicyID').val(), Optional_Cover_Amount: Actual_Amount, Optional_Cover_Utilized: 0, Optional_Cover_blocked: Current_Amount, OptionalCoverID: val, COCID: COCID, claimTypeID: $('#hdnClaimTypeID').val()},
                            success: function (result) {
                            if (result == "ErrorCode#1") {
                                alert('Your Session Expired');
                                window.location.href = "/account/Mcarelogin";
                            }
                            else if ($.parseJSON(result) != "") {
                                var OPCoverData = $.parseJSON(result);
                                var OPCover = OPCoverData.Table;
                                GetOptionalCovers();
                            }
                            else {
                                ShowResultMessage('divMUWanringBox', result);
                            }
                        },
                        error: function () {
                            DialogCommomErrorFunction('Error occurred while inserting the details')
                        }
                    }
                    );

            }

