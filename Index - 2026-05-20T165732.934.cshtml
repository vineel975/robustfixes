<script>
    function openNav(elem, val) {
        $("#tablebodyCashlessLog").html("");
        var $nav = $("#myNav");
        // Get position of clicked icon
        var offset = $(elem).offset();
        var iconHeight = $(elem).outerHeight();
        // Place overlay near the clicked element
        $nav.css({
            top: offset.top - 50 + "px",  // show below the icon
            right: 150 + "px",           // adjust horizontally (center align)
            display: "block",
            position: "absolute"
        });
        $.ajax({
            //type: "POST",
            url: "/MedicalScrutiny/FetchCashlessSuccessFailedLogs",
            contentType: 'application/json;charset=utf-8',
            //processData: false,
            data: { ClaimID: $("#hdnClaimID").val(), SlNo: $("#hdnClaimSlNo").val(), tabid: val },
            success: function (data) {
                data = $.parseJSON(data);

                if (data == null || data == "") {
                    //alert('Data not found.');
                }
                else {

                    var tableData = ''
                    $("#tablebodyCashlessLog").html("");
                    $.each(data, function (index) {
                        tableData = tableData + '<tr>';
                        tableData = tableData + '<td style="text-align:center;">';
                        if (data[index].ExecFlag == "0") {
                            tableData = tableData + '<i class="fa fa-close" style="color:#ff0000"></i>';
                        }
                        else {
                            tableData = tableData + '<i class="fa fa-check" style="color:#82af6f"></i>';
                        }
                        tableData = tableData + '</td>';

                        tableData = tableData + '<td>' + data[index].Message + '</td>';
                        tableData = tableData + '<td>' + data[index].Tab_Name + '</td>';
                        tableData = tableData + '</tr>';
                    });
                    $("#tablebodyCashlessLog").html(tableData);
                }
            },
            error: function (e, x) {
                ShowResultMessage('ErrorMessage', e.responseText);
            }
        });
        $("#myNav").show();
        document.getElementById("myNav").style.height = "300px";
    }

    function closeNav() {
        document.getElementById("myNav").style.height = "0px";
    }
</script>
