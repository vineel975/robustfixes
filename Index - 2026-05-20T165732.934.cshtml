            // ── Staging global functions (must be global scope) ─────────────────
        function claimAI_fireWebhook(claimID, slNo) {
            var claimAiUrl = '@System.Configuration.ConfigurationManager.AppSettings["claimAIUrl"]' || 'http://localhost:3000';
            var stagingKey = '@System.Configuration.ConfigurationManager.AppSettings["StagingApiKey"]' || '';
            $.ajax({
                url:         claimAiUrl + '/api/staging/webhook',
                method:      'POST',
                contentType: 'application/json',
                headers:     { 'x-api-key': stagingKey },
                data:        JSON.stringify({ claimId: claimID.toString(), slNo: (slNo || '1').toString() }),
                success: function(res) { console.log('[ClaimAI] Staging webhook:', res.status); },
                error:   function()    { console.log('[ClaimAI] Staging webhook failed — will use on-demand'); }
            });
        }

        function claimAI_checkStagingAndLoad(claimID, slNo, onDemandFn) {
            var claimAiUrl = '@System.Configuration.ConfigurationManager.AppSettings["claimAIUrl"]' || 'http://localhost:3000';
            var stagingKey = '@System.Configuration.ConfigurationManager.AppSettings["StagingApiKey"]' || '';
            $.ajax({
                url:     claimAiUrl + '/api/staging/summary',
                method:  'GET',
                headers: { 'x-api-key': stagingKey },
                data:    { claimId: claimID.toString(), slNo: (slNo || '1').toString() },
                timeout: 2000,
                success: function(res) {
                    console.log('[ClaimAI] Staging status:', res.status, res.jobId || '');
                    if (res.status === 'done' && res.jobId) {
                        console.log('[ClaimAI] Staging ready — loading iframe for jobId:', res.jobId);
                        _setAllIframeSrcs(res.jobId, res);
                    } else if (res.status === 'pending' || res.status === 'processing') {
                        console.log('[ClaimAI] Staging pending — polling...');
                        claimAI_pollStaging(claimID, slNo, onDemandFn, claimAiUrl, stagingKey, 0);
                    } else {
                        console.log('[ClaimAI] Staging not found — using on-demand');
                        onDemandFn();
                    }
                },
                error: function() {
                    console.log('[ClaimAI] Staging unreachable — using on-demand');
                    onDemandFn();
                }
            });
        }

        function claimAI_pollStaging(claimID, slNo, onDemandFn, claimAiUrl, stagingKey, attempts) {
            if (attempts >= 12) {
                console.log('[ClaimAI] Staging poll timeout — falling back to on-demand');
                onDemandFn();
                return;
            }
            setTimeout(function() {
                $.ajax({
                    url:     claimAiUrl + '/api/staging/summary',
                    method:  'GET',
                    headers: { 'x-api-key': stagingKey },
                    data:    { claimId: claimID.toString(), slNo: (slNo || '1').toString() },
                    timeout: 3000,
                    success: function(res) {
                        if (res.status === 'done' && res.jobId) {
                            console.log('[ClaimAI] Staging ready after poll, jobId:', res.jobId);
                            _setAllIframeSrcs(res.jobId, res);
                        } else if (res.status === 'pending' || res.status === 'processing') {
                            claimAI_pollStaging(claimID, slNo, onDemandFn, claimAiUrl, stagingKey, attempts + 1);
                        } else {
                            onDemandFn();
                        }
                    },
                    error: function() { onDemandFn(); }
                });
            }, 5000);
        }

        function _setAllIframeSrcs(jobId, stagingData) {
            var claimAiUrl = '@System.Configuration.ConfigurationManager.AppSettings["claimAIUrl"]' || 'http://localhost:3000';
            var stagingKey = '@System.Configuration.ConfigurationManager.AppSettings["StagingApiKey"]' || '';

            // Load iframe
            var src = claimAiUrl + '/job/' + encodeURIComponent(jobId) + '?embedded=1'
                    + (window._claimAI_reqFacilityName ? '&availedAccom=' + encodeURIComponent(window._claimAI_reqFacilityName) : '');
            console.log('[ClaimAI] Staging setting iframe src:', src);
            $('#divAiLoading').hide();
            var $ifr = $('#ifrClaimAI').attr('src', src).show();

            // Step 3: After iframe loads, send pre-calculated benefit limit + facility options
            $ifr.off('load.staging').on('load.staging', function() {
                var ifrWin = this.contentWindow;
                if (!ifrWin) return;
                // Send facility options
                claimAI_sendFacilityOptions();
                // Send pre-calculated benefit limit if available
                if (stagingData && stagingData.preBenefitLimit) {
                    ifrWin.postMessage({
                        source:             'spectra',
                        type:               'codingProcedureLimitResult',
                        success:            true,
                        noLimit:            false,
                        eligibleAmount:     parseFloat(stagingData.preBenefitLimit),
                        ruleName:           stagingData.preBenefitRuleName || '',
                        warning:            stagingData.preBenefitWarning  || undefined
                    }, '*');
                    console.log('[ClaimAI] Staging: sent pre-calculated benefit limit:', stagingData.preBenefitLimit);
                }
            });

            $('#ifrClaimAI2, #ifrClaimAI3, #ifrClaimAI4').attr('src', src);
        }

